<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Регистрация"
            android:textColor="@color/accent_gold"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Создайте свой аккаунт"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/etRegFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ФИО"
            style="@style/DarkEditText"
            android:inputType="textPersonName|textCapWords"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/etRegUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Логин (мин. 3 символа)"
            style="@style/DarkEditText"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/etRegPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Пароль (мин. 6 символов)"
            style="@style/DarkEditText"
            android:inputType="textPassword"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/etRegEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            style="@style/DarkEditText"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp"/>

        <EditText
            android:id="@+id/etRegPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Телефон"
            style="@style/DarkEditText"
            android:inputType="phone"
            android:imeOptions="actionDone"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зарегистрироваться"
            style="@style/GoldButton"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvGoLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="Уже есть аккаунт? Войти"
            android:textColor="@color/accent_gold"
            android:textSize="15sp"/>

    </LinearLayout>
</ScrollView>
