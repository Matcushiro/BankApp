<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- ═══ Toolbar ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnTransferBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/btn_back"
            android:tint="@color/accent_gold"
            android:contentDescription="Назад"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Перевод"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="14dp"/>
    </LinearLayout>

    <!-- ═══ Content ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Подсказка -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Переводите средства другим пользователям. Укажите логин получателя, выберите счета и введите сумму."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"
                android:lineSpacingMultiplier="1.3"/>

            <!-- Форма перевода -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/dark_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Со счёта -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Со счёта:"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerFromAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:popupBackground="@color/dark_card"
                        android:layout_marginBottom="18dp"/>

                    <!-- Получатель -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Получатель (логин):"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etTransferUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Логин пользователя"
                        style="@style/DarkEditText"
                        android:inputType="text"
                        android:imeOptions="actionNext"
                        android:layout_marginBottom="18dp"/>

                    <!-- На счёт -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="На счёт получателя:"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerToAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/input_bg"
                        android:padding="12dp"
                        android:popupBackground="@color/dark_card"
                        android:layout_marginBottom="18dp"/>

                    <!-- Сумма -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Сумма:"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etTransferAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        style="@style/DarkEditText"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"
                        android:layout_marginBottom="24dp"/>

                    <Button
                        android:id="@+id/btnDoTransfer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Перевести"
                        style="@style/GoldButton"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
