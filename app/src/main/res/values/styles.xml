<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  КНОПКИ                                                           -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Золотая кнопка (основное действие) -->
    <style name="GoldButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_gold</item>
        <item name="android:textColor">@color/dark_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Outline-кнопка (вторичное действие, золотая рамка) -->
    <style name="OutlineButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_outline</item>
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">11dp</item>
        <item name="android:paddingBottom">11dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Danger-кнопка (красная, деструктивное действие) -->
    <style name="DangerButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_danger</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">9dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  ПОЛЯ ВВОДА                                                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Тёмное поле ввода -->
    <style name="DarkEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:cursorVisible">true</item>
    </style>

</resources>
